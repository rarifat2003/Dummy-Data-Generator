<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Dummy Data Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <%- include('navbar.ejs'); %>

        <div class="container text-center my-5">
            <h1 class="mb-4">Database Operations Hub</h1>

            <button id="btnGenerate" class="btn btn-primary btn-lg mx-2">Generate 10 Records</button>
            <button id="btnDelete" class="btn btn-danger btn-lg mx-2">Wipe Database</button>
        </div>
    

    <script>
        document.getElementById('btnGenerate').addEventListener('click', async () => {
            const response = await fetch('/generate');
            const statusText = await response.text();
            alert(statusText);
        });

        document.getElementById('btnDelete').addEventListener('click', async () => {
            const userConfirmed = confirm("⚠️ WARNING: Are you absolutely sure you want to clear the entire database? This action cannot be undone.");
            if (!userConfirmed) {
                return;
            }
            try {
                const response = await fetch('/delete');
                const statusText = await response.text();
                showNotification(statusText, true);
            } catch (err) {
                showNotification("Error connecting to server.", true);
            }
        });


    </script>
    <script src="script.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>